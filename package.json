{
  "name": "@tomsd/mongodbclient",
  "version": "4.4.5",
  "description": "It's a handy mongodb client for easy-use.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/mongodbclient.d.mts",
      "import": "./dist/mongodbclient.mjs",
      "require": "./dist/mongodbclient.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "biome check",
    "prepare": "husky",
    "start-db": "docker compose up -d",
    "stop-db": "docker compose down",
    "serve:doc": "mdbook --serve --directory docs",
    "test": "vitest --project node",
    "test:local": "vitest --project local"
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "biome check"
    ]
  },
  "keywords": [
    "mongodb"
  ],
  "author": "tom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomsdoo/mongodbclient"
  },
  "dependencies": {
    "mongodb": "7.2.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tomsd/md-book": "2.0.10",
    "@types/node": "25.7.0",
    "@types/uuid": "11.0.0",
    "dotenv": "17.4.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "tsdown": "0.22.0",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
